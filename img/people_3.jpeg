.wpcf7 textarea
{
width: -webkit-fill-available;
padding: 15px 10px;
border: 1px solid #ccc;
border-radius: 7.5px;
resize: none;
}

.wpcf7 label
{
font-size: 1rem;
}

.wpcf7-submit
{
font-size: 1.5rem;
color: #fff;
background-color: #e41e2f;
border: none !important;
box-shadow: none;
}

.wpcf7-submit:hover
{
cursor: pointer;
}

#searchwp-form-1 .swp-input
{
margin: 20px !important;
padding: 15px !important;
border: none !important;
}
